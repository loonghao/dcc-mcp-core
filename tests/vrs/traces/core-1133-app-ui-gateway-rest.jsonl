{"_vrs": {"version": 1}, "trace_id": "core-1133-app-ui-gateway-rest", "title": "app_ui gateway REST discovery, describe metadata, and call envelope", "skip_preflight": {"http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui", "limit": 1}}, "skip_when": {"json_pointer": "/total", "equals": 0}}}
{"id": "find_app_ui_snapshot", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui__snapshot", "limit": 1}}, "expect": {"status": 200, "body_contains": "app_ui__snapshot"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "slug"}}
{"id": "describe_app_ui_carries_metadata", "http": {"method": "POST", "path": "/v1/describe", "json": {"tool_slug": "{{capture:slug}}"}}, "expect": {"status": 200, "body_contains": "timeoutHintSecs"}}
{"id": "call_app_ui_preserves_output_envelope", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:slug}}", "arguments": {"session_id": "core-1133-vrs"}}}, "expect": {"status": 200, "json_subset": {"output": {"success": true}}}}

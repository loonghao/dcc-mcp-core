{"_vrs": {"version": 1}, "trace_id": "core-1134-app-ui-mock-workflow", "title": "app_ui mock workflow and recovery envelopes through REST", "skip_preflight": {"http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui__snapshot", "limit": 1}}, "skip_when": {"json_pointer": "/total", "equals": 0}}}
{"id": "load_app_ui_skill", "http": {"method": "POST", "path": "/v1/load_skill", "json": {"skill_name": "app-ui"}}, "expect": {"status": 200, "body_contains": "app-ui"}}
{"id": "find_snapshot_tool", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui__snapshot", "limit": 1}}, "expect": {"status": 200, "body_contains": "app_ui__snapshot"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "snapshot_slug"}}
{"id": "find_find_tool", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui__find", "limit": 1}}, "expect": {"status": 200, "body_contains": "app_ui__find"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "find_slug"}}
{"id": "find_act_tool", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui__act", "limit": 1}}, "expect": {"status": 200, "body_contains": "app_ui__act"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "act_slug"}}
{"id": "find_wait_tool", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "app_ui__wait_for", "limit": 1}}, "expect": {"status": 200, "body_contains": "app_ui__wait_for"}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "wait_slug"}}
{"id": "snapshot_settings_panel", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:snapshot_slug}}", "arguments": {"session_id": "core-1134-vrs"}}}, "expect": {"status": 200, "json_subset": {"output": {"success": true}}}, "capture": {"json_pointer": "/output/context/snapshot_id", "as": "snapshot_id"}}
{"id": "find_project_name", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:find_slug}}", "arguments": {"session_id": "core-1134-vrs", "label": "Project name"}}}, "expect": {"status": 200, "body_contains": "project-name"}, "capture": {"json_pointer": "/output/context/matches/0/id", "as": "project_control"}}
{"id": "set_project_name", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:act_slug}}", "arguments": {"session_id": "core-1134-vrs", "control_id": "{{capture:project_control}}", "action": "set_text", "text": "Hero", "snapshot_id": "{{capture:snapshot_id}}"}}}, "expect": {"status": 200, "json_subset": {"output": {"success": true}}}, "capture": {"json_pointer": "/output/context/snapshot_id", "as": "updated_snapshot_id"}}
{"id": "wait_project_name", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:wait_slug}}", "arguments": {"session_id": "core-1134-vrs", "condition": {"kind": "value_equals", "control_id": "{{capture:project_control}}", "value": "Hero", "timeout_ms": 500, "interval_ms": 25}}}}, "expect": {"status": 200, "json_subset": {"output": {"success": true}}}}
{"id": "stale_control_is_structured", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:act_slug}}", "arguments": {"session_id": "core-1134-vrs", "control_id": "enable-cache", "action": "toggle", "snapshot_id": "{{capture:snapshot_id}}"}}}, "expect": {"status": 200, "body_contains": "stale_control", "json_subset": {"output": {"success": false}}}}
{"id": "policy_denied_is_structured", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:act_slug}}", "arguments": {"session_id": "core-1134-vrs", "control_id": "{{capture:project_control}}", "action": "set_text", "text": "Secret", "snapshot_id": "{{capture:updated_snapshot_id}}", "policy": {"allow_text_entry": false}}}}, "expect": {"status": 200, "body_contains": "policy_disabled", "json_subset": {"output": {"success": false}}}}
{"id": "timeout_is_structured", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:wait_slug}}", "arguments": {"session_id": "core-1134-vrs", "condition": {"kind": "text_equals", "control_id": "status", "text": "Never", "timeout_ms": 1, "interval_ms": 1}}}}, "expect": {"status": 200, "body_contains": "timeout", "json_subset": {"output": {"success": false}}}}
{"id": "missing_window_is_structured", "http": {"method": "POST", "path": "/v1/call", "json": {"tool_slug": "{{capture:snapshot_slug}}", "arguments": {"session_id": "core-1134-vrs", "policy": {"allowed_window_titles": ["Not This Window"]}}}}, "expect": {"status": 200, "body_contains": "missing_window", "json_subset": {"output": {"success": false}}}}

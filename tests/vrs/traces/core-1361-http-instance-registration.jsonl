{"_vrs": {"version": 1}, "trace_id": "core-1361-http-instance-registration", "title": "Gateway REST accepts remote HTTP instance registration with TTL heartbeat and deregister"}
{"id": "register_remote_instance", "http": {"method": "POST", "path": "/v1/instances/register", "json": {"instance_id": "11111111-1111-4111-8111-111111111111", "dcc_type": "maya", "mcp_url": "http://127.0.0.1:9/mcp", "capabilities_fingerprint": "fp-1", "scene": "remote.ma", "ttl_secs": 30}}, "expect": {"status": 200, "json_subset": {"ok": true, "operation": "registered", "instance_id": "11111111-1111-4111-8111-111111111111", "heartbeat_interval_secs": 10}}}
{"id": "list_registered_instance", "http": {"method": "GET", "path": "/v1/instances"}, "expect": {"status": 200, "json_subset": {"total": 1, "instances": [{"instance_id": "11111111-1111-4111-8111-111111111111", "dcc_type": "maya", "mcp_url": "http://127.0.0.1:9/mcp", "source": "http", "scene": "remote.ma"}]}}}
{"id": "heartbeat_updates_scene", "http": {"method": "POST", "path": "/v1/instances/heartbeat", "json": {"instance_id": "11111111-1111-4111-8111-111111111111", "capabilities_fingerprint": "fp-2", "scene": "remote-updated.ma"}}, "expect": {"status": 200, "json_subset": {"ok": true, "operation": "heartbeat", "instance_id": "11111111-1111-4111-8111-111111111111"}}}
{"id": "path_call_resolves_http_instance", "http": {"method": "POST", "path": "/v1/dcc/maya/instances/11111111/call", "json": {"backend_tool": "example_tool", "arguments": {}}}, "expect_any": [{"status": 404, "body_contains": "unknown-slug"}, {"status": 503, "body_contains": "instance-offline"}]}
{"id": "deregister_remote_instance", "http": {"method": "POST", "path": "/v1/instances/deregister", "json": {"instance_id": "11111111-1111-4111-8111-111111111111"}}, "expect": {"status": 200, "json_subset": {"ok": true, "operation": "deregistered", "instance_id": "11111111-1111-4111-8111-111111111111"}}}
{"id": "list_after_deregister", "http": {"method": "GET", "path": "/v1/instances"}, "expect": {"status": 200, "json_subset": {"total": 0, "instances": []}}}

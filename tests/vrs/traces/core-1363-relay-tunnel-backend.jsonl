{"_vrs": {"version": 1, "skip_preflight": {"http": {"method": "GET", "path": "/v1/instances"}, "skip_when": {"body_not_contains": "\"source\":\"relay\""}}}, "trace_id": "core-1363", "title": "Gateway sees relay-backed tunnel rows and can describe relayed tools"}

{"_vrs": {"version": 1, "skip_preflight": {"http": {"method": "GET", "path": "/v1/instances"}, "skip_when": {"body_not_contains": "\"source\":\"relay\""}}}, "trace_id": "core-1364-unified-instances", "title": "gateway://instances exposes merged relay and HTTP sources with by_source counts"}
{"id": "register_http_source", "http": {"method": "POST", "path": "/v1/instances/register", "json": {"instance_id": "11111111-1111-4111-8111-111111111111", "dcc_type": "maya", "mcp_url": "http://127.0.0.1:9/mcp", "capabilities_fingerprint": "fp-http", "scene": "http.ma", "ttl_secs": 30}}, "expect": {"status": 200, "json_subset": {"ok": true, "operation": "registered", "instance_id": "11111111-1111-4111-8111-111111111111"}}}
{"id": "read_gateway_instances_resource", "http": {"method": "POST", "path": "/mcp", "json": {"jsonrpc": "2.0", "id": 1, "method": "resources/read", "params": {"uri": "gateway://instances"}}}, "expect": {"status": 200, "body_contains_all": ["by_source", "instance_short", "source_meta", "relay", "http", "/tunnel/"]}}
{"id": "deregister_http_source", "http": {"method": "POST", "path": "/v1/instances/deregister", "json": {"instance_id": "11111111-1111-4111-8111-111111111111"}}, "expect": {"status": 200, "json_subset": {"ok": true, "operation": "deregistered", "instance_id": "11111111-1111-4111-8111-111111111111"}}}

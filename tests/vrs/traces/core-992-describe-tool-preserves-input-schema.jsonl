{"_vrs": {"version": 1}, "trace_id": "core-992-describe-preserves-schema", "title": "describe_tool round-trips inputSchema.properties for a backend tool that declares them (regression #992 / #857)", "skip_preflight": {"http": {"method": "POST", "path": "/v1/search", "json": {"query": "create_cube", "dcc_type": "maya", "limit": 1}}, "skip_when": {"json_pointer": "/total", "equals": 0}}}
{"id": "find_a_known_parameterised_tool", "http": {"method": "POST", "path": "/v1/search", "json": {"query": "create_cube", "dcc_type": "maya", "limit": 1}}, "expect": {"status": 200, "body_contains": "\"tool_slug\""}, "capture": {"json_pointer": "/hits/0/tool_slug", "as": "slug"}}
{"id": "describe_must_carry_properties", "http": {"method": "POST", "path": "/v1/describe", "json": {"tool_slug": "{{capture:slug}}"}}, "expect": {"status": 200, "body_contains": "\"properties\""}}
{"id": "describe_record_must_advertise_has_schema", "http": {"method": "POST", "path": "/v1/describe", "json": {"tool_slug": "{{capture:slug}}"}}, "expect": {"status": 200, "json_subset": {"record": {"has_schema": true}}}}

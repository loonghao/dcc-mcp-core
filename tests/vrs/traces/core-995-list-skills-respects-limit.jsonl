{"_vrs": {"version": 1}, "trace_id": "core-995-list-skills-respects-limit", "title": "list_skills accepts limit/offset/fields and stays under a payload budget (regression #995 / #582)", "skip_preflight": {"http": {"method": "POST", "path": "/v1/instances", "json": null}, "skip_when": {"json_pointer": "/total", "less_than": 1}}}
{"id": "default_response_must_remain_under_8KB_for_typical_DCC_skill_count", "http": {"method": "POST", "path": "/v1/list_skills", "json": {"dcc_type": "maya"}}, "expect": {"status": 200, "json_subset": {"truncated": false}}}
{"id": "explicit_limit_must_cap_skill_count", "http": {"method": "POST", "path": "/v1/list_skills", "json": {"dcc_type": "maya", "limit": 3}}, "expect": {"status": 200, "json_subset": {"limit": 3}}}
{"id": "fields_selector_must_drop_description_when_unrequested", "http": {"method": "POST", "path": "/v1/list_skills", "json": {"dcc_type": "maya", "limit": 1, "fields": ["name"]}}, "expect": {"status": 200, "body_contains": "\"name\""}}

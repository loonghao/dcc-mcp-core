{"_vrs": {"version": 1}, "trace_id": "maya-export-fbx-describe-path-schema", "title": "maya_geometry__export_fbx: search/describe expose required path (not destination) while skill unloaded; wrong arg must not succeed", "skip_preflight": {"http": {"method": "POST", "path": "/v1/search", "json": {"query": "export_fbx", "dcc_type": "maya", "limit": 1}}, "skip_when": {"json_pointer": "/total", "equals": 0}}}
